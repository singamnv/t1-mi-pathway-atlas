{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendContactEmailViaSES",
      "Effect": "Allow",
      "Action": ["ses:SendEmail"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": "admin@thecviu.com"
        }
      }
    }
  ]
}
